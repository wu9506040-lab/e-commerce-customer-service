# =============================================================
# 生产环境配置模板（云平台部署用）
#
# 部署步骤：
#   1. cp deploy/.env.prod.example deploy/.env.prod
#   2. 编辑 .env.prod 填真实 key（Qwen API Key、JWT_SECRET 等）
#   3. docker compose -f deploy/docker-compose.prod.yml --env-file deploy/.env.prod up -d --build
#
# 安全要求：
#   - QWEN_API_KEY / JWT_SECRET 必须替换为随机强密钥
#   - COOKIE_SECURE 必须 true（HTTPS）
#   - DATA_ROOT 用绝对路径（Ubuntu: /data/customer-service）
# =============================================================

# ---- 数据卷根路径（Ubuntu 推荐 /data/customer-service）----
DATA_ROOT=/data/customer-service

# ---- Compose 项目名（隔离）----
COMPOSE_PROJECT_NAME=customer-service-prod

# ---- MySQL 配置（生产：必须强密码）----
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_root_pw_32chars
MYSQL_DATABASE=customer_service
MYSQL_USER=customer_service
MYSQL_PASSWORD=CHANGE_ME_strong_user_pw_32chars

# ---- Qwen DashScope LLM ----
# 从 https://dashscope.console.aliyun.com/apiKey 获取
QWEN_API_KEY=sk-CHANGE_ME_real_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 生产建议 qwen-max 或 qwen-plus（更高质量）
QWEN_MODEL=qwen-max

# ---- Qdrant ----
QDRANT_COLLECTION=knowledge_base

# ---- JWT 强密钥（openssl rand -hex 32）----
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32_xxx
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ---- bcrypt ----
BCRYPT_ROUNDS=12

# ---- Cookie（HTTPS 必须 secure=true）----
COOKIE_NAME=cs_token
COOKIE_MAX_AGE=86400
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# ---- 应用 ----
APP_ENV=prod
LOG_LEVEL=INFO
USE_LANGGRAPH_REFUND=true

# ---- 速率限制（开放 demo 必加）----
# per-IP per-minute 上限（防止被刷 token）
RATE_LIMIT_PER_MINUTE=30
