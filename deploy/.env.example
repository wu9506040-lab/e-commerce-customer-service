# =============================================================
# 智能客服 Agent 系统 - 环境变量模板
# 复制为 .env.dev 后填入真实值，.env 文件加入 .gitignore
#
# 字段顺序与 backend/app/core/config.py 对齐（pydantic-settings）
# =============================================================

# ---- 数据卷根路径（所有持久化数据都在这下面）----
# Windows 路径用反斜杠，Docker Desktop 自动转换
DATA_ROOT=E:\DockerData\volumes

# ---- Compose 项目名（影响容器/网络/卷前缀）----
COMPOSE_PROJECT_NAME=customer-service

# ---- MySQL 配置 ----
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=customer_service
MYSQL_USER=customer_service
MYSQL_PASSWORD=change_me_user_password

# ---- Qwen (DashScope) LLM 配置 ----
# API Key 从 https://dashscope.console.aliyun.com/apiKey 获取
QWEN_API_KEY=sk-change_me_qwen_api_key
# DashScope OpenAI 兼容模式端点
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 默认模型（可选: qwen-max / qwen-plus / qwen-turbo / qwen-long）
QWEN_MODEL=qwen-max

# ---- Qdrant 向量库配置 ----
# QDRANT_URL 走 docker compose 内置（http://qdrant:6333），无需外部覆盖
QDRANT_COLLECTION=knowledge_base

# ---- JWT 配置 ----
# 至少 32 字符随机字符串（生产必须替换为 openssl rand -hex 32 生成的强密钥）
JWT_SECRET=change_me_at_least_32_chars_random_xxx_string_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ---- bcrypt 配置 ----
# 密码哈希轮数（10-14 之间；越慢越安全）
BCRYPT_ROUNDS=12

# ---- Cookie 配置 ----
# dev 下 COOKIE_SECURE=false 便于 curl；生产必须 true
COOKIE_NAME=cs_token
COOKIE_MAX_AGE=86400
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ---- 应用配置 ----
APP_ENV=dev
LOG_LEVEL=INFO
