deploy/tests/cookies.txt

# =============================================================
# 电商知识库数据（本地保留，不上传公开仓库）
# - scripts/ingest_ecommerce_kb.py 会读取本地数据入库 Qdrant
# - 数据本身是通用电商知识，但保留本地避免污染公开仓库
# =============================================================
docs/ecommerce_kb/

# =============================================================
# 私人文档（简历/笔记/草稿，不上传公开仓库）
# 必须用 /** 而不是 /，否则只忽略目录本身，文件会泄露到公开仓库
# =============================================================
docs/_private/**
!/docs/_private/.gitkeep

# =============================================================
# 调试过程截图（bug 复现/audit 调试，不上传公开仓库）
# =============================================================
frontend/_screenshots/audit/
frontend/_screenshots/bugrepro/

# =============================================================
# 内部测试报告（idor / regression_m13 / 性能压测等，含漏洞细节 + 压测数据，不上传公开仓库）
# 2026-07-05：所有 _report.json 不再 tracked，已 git rm --cached
# 仅保留 frontend/_screenshots/walkthrough/ 下的 demo 截图 + 公开 walkthrough/report.json
# =============================================================
frontend/_screenshots/*_report.json
